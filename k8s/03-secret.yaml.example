# 이 파일은 git에 커밋된다. 실제 자격증명은 SealedSecrets 또는 운영자 수동 적용으로 관리할 것.
# 사용법: 이 파일을 03-secret.yaml로 복사 후 users.txt 내용 채워서 apply.

apiVersion: v1
kind: Secret
metadata:
  name: vsftpd-users
  namespace: ftp
type: Opaque
stringData:
  users.txt: |
    alice
    alicepw_replace_me
    bob
    bobpw_replace_me
